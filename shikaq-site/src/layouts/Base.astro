---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = '/og-image.png' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const plausibleDomain = import.meta.env['PUBLIC_PLAUSIBLE_DOMAIN'] ?? '';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:site_name" content="shikaq" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Plausible Analytics (cookieless) -->
    {plausibleDomain.length > 0 && (
      <script
        defer
        src="https://plausible.io/js/script.js"
        data-domain={plausibleDomain}
      />
    )}

    <!-- JSON-LD Organization -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "shikaq",
        "url": "https://shikaq.app",
        "description": "ITパスポート・基本情報技術者・SPI・簿記2級に対応した資格学習サブスク。月額980円。"
      }
    </script>
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>

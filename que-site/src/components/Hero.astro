---
const certifications = ['ITパスポート', '基本情報技術者', 'SPI', '簿記2級'];
---

<section class="relative min-h-screen flex flex-col items-center justify-center px-6 overflow-hidden">
  <!-- Background subtle gradient orb -->
  <div
    class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full opacity-[0.06] pointer-events-none"
    style="background: radial-gradient(circle, #0600FF 0%, #7A0085 100%);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-3xl mx-auto text-center">
    <!-- Wordmark -->
    <p class="text-sm font-semibold tracking-widest uppercase mb-8" style="color: var(--color-tertiary-label);">
      shikaq
    </p>

    <!-- Headline -->
    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-semibold leading-tight tracking-tight mb-6">
      <span id="cert-text" class="brand-gradient-text transition-opacity duration-500">ITパスポート</span>
      <br />
      <span style="color: var(--color-label);">を、shikaqで。</span>
    </h1>

    <!-- Sub -->
    <p class="text-xl sm:text-2xl mb-12 leading-relaxed" style="color: var(--color-secondary-label);">
      参考書を広げなくていい。<br class="sm:hidden" />
      iPad 一台で合格まで届く、資格学習サブスク。
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="https://shikaq-app.vercel.app/onboarding"
        class="brand-gradient text-white px-8 py-4 rounded-2xl text-lg font-semibold tracking-tight transition-transform duration-200 hover:scale-[1.02] active:scale-[0.98]"
      >
        shikaq を始める
      </a>
      <a
        href="#features"
        class="px-8 py-4 rounded-2xl text-lg font-medium transition-colors duration-200"
        style="color: var(--color-tint);"
      >
        詳しく見る
      </a>
    </div>

    <!-- Price hint -->
    <p class="mt-8 text-sm" style="color: var(--color-tertiary-label);">
      月額 ¥980（税込）。無料体験あり。いつでも解約できます。
    </p>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1" style="color: var(--color-tertiary-label);">
    <span class="text-xs tracking-wider">SCROLL</span>
    <div class="w-px h-8 animate-pulse" style="background: var(--color-tertiary-label);"></div>
  </div>
</section>

<script define:vars={{ certifications }}>
  const el = document.getElementById('cert-text');
  if (el) {
    let idx = 0;
    setInterval(() => {
      el.style.opacity = '0';
      setTimeout(() => {
        idx = (idx + 1) % certifications.length;
        el.textContent = certifications[idx];
        el.style.opacity = '1';
      }, 300);
    }, 2400);
  }
</script>

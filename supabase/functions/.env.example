# Edge Functions 用の環境変数
# 本番に流す時は `supabase secrets set --env-file ./supabase/functions/.env`

# Stripe (テストモードのキーで開発開始)
# Stripe Dashboard → Developers → API keys から取得
STRIPE_SECRET_KEY=<your-stripe-test-secret-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-signing-secret>
STRIPE_PRICE_ID=<your-stripe-price-id>
# DeepSeek (AI Q&A / 問題ドラフト生成用)
DEEPSEEK_API_KEY=<your-deepseek-api-key>
# ElevenLabs (音声解説 TTS)
ELEVENLABS_API_KEY=<your-elevenlabs-api-key>
ELEVENLABS_VOICE_ID=<voice-id-from-elevenlabs-voices>
SENTRY_DSN=<your-sentry-dsn-optional>

# アプリの URL (Checkout 成功 / キャンセル 時のリダイレクト先)
APP_URL=http://localhost:8081

# OAuth プロバイダ (Supabase Auth)
# Google: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URIs に http://127.0.0.1:54321/auth/v1/callback を追加
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Apple: Apple Developer → Certificates, Identifiers & Profiles → Services ID
# secret は ES256 で署名した JWT (有効期限 6 ヶ月)。詳細: https://supabase.com/docs/guides/auth/social-login/auth-apple
SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=
